# ---- Core ----
NODE_ENV=development
PORT=4000

# ---- Database (MongoDB) ----
# Local dev: use the docker-compose Mongo below. Production: MongoDB Atlas M0 (free).
MONGODB_URI=mongodb://127.0.0.1:27017/skillbridge

# ---- Auth ----
# Use a long random string (>= 16 chars). REQUIRED in production.
JWT_SECRET=change-me-to-a-long-random-string

# ---- CORS ----
# Comma-separated list of allowed frontend origins.
CORS_ORIGIN=http://localhost:5173

# ---- App URL (for links in emails, e.g. password reset) ----
# Defaults to the first CORS_ORIGIN. In production set it to your deployed frontend URL.
APP_URL=http://localhost:5173

# ---- Email (SMTP) — OPTIONAL ----
# If these are unset, password-reset emails are LOGGED to the server console instead of sent
# (so the flow is testable in dev). To send real emails, use any SMTP provider
# (Brevo, Gmail app-password, Mailtrap, etc.).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=SkillBridge <no-reply@skillbridge.app>

# ---- AI providers (free tiers) ----
# Google Gemini is the DEFAULT engine. Paste your free key here (from Google AI Studio).
# Leave GROQ_API_KEY blank to use Gemini only; set it to enable automatic fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Logging ----
LOG_LEVEL=info
